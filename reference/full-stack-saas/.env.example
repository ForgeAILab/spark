# Postgres database used by Drizzle, Better Auth, and Zero.
# docker-compose stack provides Postgres at port 5432
DATABASE_URL=postgres://anvil:anvil@localhost:5432/anvil

# Better Auth local secret and canonical app URL.
BETTER_AUTH_SECRET=reference-dev-secret-change-me-reference-dev-secret-change-me
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth credentials for Better Auth social sign-in.
GITHUB_CLIENT_ID=github-client-id
GITHUB_CLIENT_SECRET=github-client-secret

# Stripe API key, webhook secret, and subscription price used by smoke routes.
STRIPE_SECRET_KEY=sk_test_reference
STRIPE_WEBHOOK_SECRET=whsec_reference
STRIPE_PRICE_ID=price_reference

# Resend API key and default sender for transactional email.
RESEND_API_KEY=re_reference
RESEND_FROM_EMAIL="Reference App <onboarding@resend.dev>"

# Anthropic API key for the streaming chat endpoint.
ANTHROPIC_API_KEY=sk-ant-reference

# Zero auth secret and browser cache URL.
ZERO_AUTH_SECRET=zero-reference-secret-change-me
NEXT_PUBLIC_ZERO_URL=http://localhost:4848
ZERO_UPSTREAM_DB=postgres://anvil:anvil@localhost:5432/anvil
ZERO_PUSH_URL=http://localhost:3010/api/zero/mutate
