{
  "name": "@forgeailab/reference-full-stack-saas",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.18",
  "scripts": {
    "predev": "bun scripts/init-db.ts",
    "dev": "bun --bun next dev",
    "prestart": "bun scripts/init-db.ts",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "test": "bun test ./test",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "db:init": "bun scripts/init-db.ts",
    "db:push": "drizzle-kit push",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f --tail=100",
    "stack:reset": "docker compose down -v",
    "zero:permissions": "bunx zero-deploy-permissions --schema-path=./lib/zero/schema.ts --upstream-db=postgres://anvil:anvil@localhost:5432/anvil"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@better-auth/drizzle-adapter": "latest",
    "@forgeailab/anvil-anthropic": "workspace:*",
    "@forgeailab/anvil-auth-better-auth": "workspace:*",
    "@forgeailab/anvil-stripe-helpers": "workspace:*",
    "@forgeailab/anvil-sync-zero": "workspace:*",
    "@radix-ui/react-slot": "latest",
    "@rocicorp/zero": "latest",
    "@tailwindcss/postcss": "^4",
    "better-auth": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "drizzle-orm": "latest",
    "lucide-react": "latest",
    "next": "^15",
    "postcss": "^8",
    "postgres": "latest",
    "react": "^19",
    "react-dom": "^19",
    "resend": "latest",
    "stripe": "latest",
    "tailwind-merge": "latest",
    "tailwindcss": "^4",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "latest",
    "drizzle-kit": "latest",
    "typescript": "^5"
  }
}
